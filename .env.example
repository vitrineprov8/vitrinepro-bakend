# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=vitronepro

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Environment
NODE_ENV=development

# OAuth - Google
# Obtener credenciales en: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=tu-google-client-id
GOOGLE_CLIENT_SECRET=tu-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# OAuth - LinkedIn
# Obtener credenciales en: https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID=tu-linkedin-client-id
LINKEDIN_CLIENT_SECRET=tu-linkedin-client-secret
LINKEDIN_CALLBACK_URL=http://localhost:3000/auth/linkedin/callback

# Frontend URL para OAuth redirects e links de e-mail (consentimento, reset, etc.)
FRONTEND_URL=http://localhost:4321

# E-mail transacional — Resend (https://resend.com). B14.
# Sem RESEND_API_KEY o MailService entra em modo STUB (loga em vez de enviar) — ok em dev.
# MAIL_FROM: em teste use "VitrinePro <onboarding@resend.dev>"; em prod, um domínio verificado.
RESEND_API_KEY=
MAIL_FROM=VitrinePro <onboarding@resend.dev>

# Public site URL — used to build absolute URLs for IndexNow pings and sitemap
PUBLIC_SITE_URL=https://v8pro.com.br

# IndexNow key — accelerates (de)indexing on Bing/Yandex/Seznam.
# Leave empty in local dev; set in Railway for production.
# The key file must be hosted at https://v8pro.com.br/<INDEXNOW_KEY>.txt
# The file already exists at vitrinepro-frontend/public/34b2b95a37ec5d8f90dc24fe8efc1801.txt
INDEXNOW_KEY=34b2b95a37ec5d8f90dc24fe8efc1801
